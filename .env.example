# Bu dosyayı .env olarak kopyalayıp doldur:  cp .env.example .env
# .env dosyası .gitignore'dadır, commit'lenmez.

# === Zorunlu ===
# Dinleyici bot hesabının token'ı (Discord Developer Portal > Bot > Token).
# Bu bot mesajları OKUR ve durum/uyarı mesajı atar.
BOT_TOKEN=

# OwO komutlarını SENİN adına gönderecek kullanıcı hesabının token'ı (self-bot kısmı).
# Authorization header'ına ham olarak konur.
BEARER_TOKEN=

# Farming yapılacak kanalın Discord API mesaj endpoint'i:
#   https://discord.com/api/v9/channels/<KANAL_ID>/messages
# Kanal ID'si buradan otomatik çıkarılır (uyarı mention'ları için).
CHANNEL_URL=

# Uyarılarda etiketlenecek sahip (senin) Discord kullanıcı ID'n.
AUTHOR_ID=

# === Telegram uyarıları (önerilir; captcha'yı telefondan görmek için) ===
# @BotFather ile bot oluşturup token'ı buraya koy. Boş bırakırsan Telegram
# uyarıları devre dışı kalır (kanal mention + log yine çalışır).
TELEGRAM_BOT_TOKEN=
# Uyarıların gideceği chat ID (kendi ID'n). @userinfobot ile öğrenebilirsin.
TELEGRAM_CHAT_ID=

# === Opsiyonel ===
# 'owob fr' ile battle yapılacak arkadaşın kullanıcı ID'si.
OTHER_AUTHOR_ID=

# === Ayarlanabilir (varsayılanlar gösterildi, hepsi opsiyonel) ===
# Hunt turları arası rastgele bekleme aralığı (saniye).
DELAY_MIN_SECONDS=30
DELAY_MAX_SECONDS=120
# Hızlı modda ('owo fast') sabit bekleme (saniye).
FAST_DELAY_SECONDS=13
# Kaç turda bir uzun mola verilsin.
BREAK_EVERY=10
# Uzun molanın süresi (saniye).
BREAK_SECONDS=240
# Captcha beklerken kaç saniyede bir tekrar uyarı gönderilsin.
CAPTCHA_REMINDER_SECONDS=60
# Bekleme öncesi "Xsn cooldown ..." örtü mesajı gönderilsin mi (true/false).
COVER_MESSAGE=true
# Log seviyesi: debug | info | warn | error
LOG_LEVEL=info
# Loglar ayrıca bu dosyaya da yazılsın (boşsa sadece stderr).
LOG_FILE=
