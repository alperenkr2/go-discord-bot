# Bu dosyayı .env olarak kopyalayıp doldur:  cp .env.example .env
# .env dosyası .gitignore'dadır, commit'lenmez.

# === Zorunlu ===
# Dinleyici bot hesabının token'ı (Discord Developer Portal > Bot > Token).
# Bu bot mesajları OKUR ve durum/uyarı mesajı atar.
BOT_TOKEN=

# OwO komutlarını SENİN adına gönderecek kullanıcı hesabının token'ı (self-bot kısmı).
# Authorization header'ına ham olarak konur.
BEARER_TOKEN=

# Farming yapılacak kanalın Discord API mesaj endpoint'i:
#   https://discord.com/api/v9/channels/<KANAL_ID>/messages
# Kanal ID'si buradan otomatik çıkarılır (uyarı mention'ları için).
CHANNEL_URL=

# Uyarılarda etiketlenecek sahip (senin) Discord kullanıcı ID'n.
AUTHOR_ID=

# === Telegram uyarıları (önerilir; captcha'yı telefondan görmek için) ===
# @BotFather ile bot oluşturup token'ı buraya koy. Boş bırakırsan Telegram
# uyarıları devre dışı kalır (kanal mention + log yine çalışır).
TELEGRAM_BOT_TOKEN=
# Uyarıların gideceği chat ID (kendi ID'n). @userinfobot ile öğrenebilirsin.
TELEGRAM_CHAT_ID=

# === Opsiyonel ===
# 'owob fr' ile battle yapılacak arkadaşın kullanıcı ID'si.
OTHER_AUTHOR_ID=

# === Ayarlanabilir (varsayılanlar gösterildi, hepsi opsiyonel) ===
# Hunt turları arası rastgele bekleme aralığı (saniye). Geniş = daha insansı.
DELAY_MIN_SECONDS=60
DELAY_MAX_SECONDS=180
# Hızlı modda ('owo fast') sabit bekleme (saniye). DİKKAT: hızlı mod captcha riskini artırır.
FAST_DELAY_SECONDS=13
# Kaç turda bir kısa mola verilsin.
BREAK_EVERY=10
# Kısa molanın süresi (saniye, ±%30 rastgele).
BREAK_SECONDS=240
# Captcha beklerken kaç saniyede bir tekrar uyarı gönderilsin.
CAPTCHA_REMINDER_SECONDS=60
# Her tur kanala çeşitli insansı mesaj gönderilsin mi (captcha'yı azaltır + XP dener).
COVER_MESSAGE=true

# === İnsansılaştırma (captcha azaltma) ===
# Botun aktif olduğu saat aralığı (0-23). Gece bu aralığın dışında "uyur".
# Örnek 10–02: sabah 10'dan gece 02'ye kadar aktif, 02–10 arası durur. Kendine göre ayarla!
ACTIVE_START_HOUR=10
ACTIVE_END_HOUR=2
# Günde en fazla kaç hunt (0 = limitsiz). İnsan kadar tutmak captcha'yı azaltır.
DAILY_HUNT_LIMIT=450
# Kaç turda bir uzun "mola verdim" arası (0 = kapalı).
LONG_BREAK_EVERY=30
# Uzun molanın rastgele süresi (saniye) — bu aralıkta seçilir.
LONG_BREAK_MIN_SECONDS=300
LONG_BREAK_MAX_SECONDS=1200
# Kanala atılacak çeşitli insansı mesaj havuzu (virgülle ayrılmış). Boşsa varsayılan havuz.
HUMAN_MESSAGES=

# === Coinflip (kumar — DİKKAT: -EV, uzun vadede KAYBETTİRİR) ===
# Sadece eğlence için. Molalarda coinflip oynar. Açmak için true yap.
GAMBLE_ENABLED=false
# Bahis aralığı (rastgele, bu iki değer arası).
GAMBLE_BET_MIN=50000
GAMBLE_BET_MAX=100000
# ASIL GÜVENLİK: günde en fazla kaç coinflip (en kötü kayıp = bu × BET_MAX).
GAMBLE_MAX_PER_DAY=10
# Günlük net kayıp bu kadar olunca o gün kumarı durdurur (0 = kapalı). Sonuç tespitine bağlı.
GAMBLE_DAILY_LOSS_LIMIT=500000

# Log seviyesi: debug | info | warn | error
LOG_LEVEL=info
# Loglar ayrıca bu dosyaya da yazılsın (boşsa sadece stderr).
LOG_FILE=
